OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.1
OLLAMA_EMBED_MODEL=nomic-embed-text
DB_PATH=./data/notes.db
MAX_TOOL_HOPS=5
HISTORY_TURNS=20
SEARCH_THRESHOLD=0.35
SEARCH_FALLBACK_LIMIT=3
# Google Gemini API key. Required only if the UI selects a Gemini model.
GEMINI_API_KEY=
# Docker-only: pre-pull a local Ollama chat model on first boot. Leave empty
# to skip (you'll need GEMINI_API_KEY for chat in that case). Examples:
# llama3.2:1b  (~1.3 GB), llama3.2  (~2 GB), qwen2.5:3b  (~2 GB).
OLLAMA_CHAT_MODEL=
